{
  "name": "ai-maestro-webdesign",
  "version": "0.1.0",
  "description": "Consolidated web-design plugin: design judgment (Claude Design principles), ASCII sketch/parse, diagrams, infographics, style extraction, and preview. amw-design-principles orchestrates every sub-skill; amw-dev-browser is the only browser-automation primitive for input workflows.",
  "author": {
    "name": "Emasoft",
    "email": "713559+Emasoft@users.noreply.github.com",
    "url": "https://github.com/Emasoft"
  },
