# macOS
.DS_Store
._*

# Dev-only, never published (per ~/.claude/CLAUDE.md Rule 0.2)
docs_dev/
scripts_dev/
samples_dev/
examples_dev/
tests_dev/
downloads_dev/
libs_dev/
builds_dev/

# Agent reports — may contain absolute paths, stack traces, PII
# (per ~/.claude/rules/agent-reports-location.md)
/reports/
/reports_dev/

# Source material — read-only references, not shipped with the plugin
/SKILLS-TO-INTEGRATE/
/claude-design-principles/

# Local environments
.venv/
venv/
env/
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.codegraph/

# Node / Bun
node_modules/
.pnp.*
dist/
build/
.next/
.turbo/
.bun/
bun.lockb

# Plugin-specific build artifacts
bin/__pycache__/
bin/*.pyc

# External vendored repos — only their build artifacts, not the source
external/*/node_modules/
external/*/dist/
external/*/build/
external/*/.turbo/
external/*/.next/

# Tool caches
.rechecker/
.tldr/
# .claude/ holds tool-cache/state (settings, hooks) — ignore its contents,
# EXCEPT the git-tracked PROJECT-scope wiki-memory under .claude/project/memory/
# (ai-maestro memory 3-scope config; stood up by /janitor-memory-bootstrap).
.claude/**
!.claude/project/
!.claude/project/memory/
!.claude/project/memory/**
.serena/
.expect/

# Test / CI output
coverage/
*.lcov
.nyc_output/

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Hyperframes vendored repo — managed as git submodule (see .gitmodules).
# The submodule itself is git-tracked via the gitlink at external/hyperframes,
# but its CONTENTS are upstream code that this plugin does not own. We tell
# CPV's gitignore-aware scanners (htmlhint, hadolint, ruff, markdownlint,
# absolute-path scan) to skip everything inside the submodule so the plugin's
# own validation report only flags issues in code we can fix (RULE 0 forbids
# editing vendored upstream sources). The submodule registration in
# .gitmodules is unaffected — git still tracks the gitlink.
external/hyperframes/**

# NOTE: external/mermaid-render/ is now OWNED first-party code (MIT, wrapping
# the MIT beautiful-mermaid backend — see Acknowledgments in README.md). It is
# git-tracked and improvable; it is NOT skipped here. Its `node_modules/` /
# `dist/` / `build/` artifacts are still ignored by the `external/*/…` rules
# above. CPV scanners now lint it like any first-party code; the wrapper
# scripts' benign process.argv / process.env CLI reads are expected.

# Vendored shadcn-ui upstream docs (skills/amw-shadcn-ui/docs/) — 201 MDX files
# imported verbatim from https://ui.shadcn.com/. These are reference material
# documenting the upstream component library; this plugin does not author them
# and re-syncs would re-introduce any local style fixes. Listing them here
# tells CPV's gitignore-aware scanners to skip them, while git continues to
# track the already-committed files (gitignore only affects untracked files —
# tracked files remain tracked, so these still ship with the plugin).
skills/amw-shadcn-ui/docs/**

# Janitor heartbeat state (per-session, transient)
.janitor/

# Added by CPV standardize
llm_externalizer_output/
*_dev/
.coverage
