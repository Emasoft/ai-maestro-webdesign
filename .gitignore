bin/__pycache__/
bin/*.pyc

# External vendored repos — only their build artifacts, not the source
external/*/node_modules/
external/*/dist/
external/*/build/
external/*/.turbo/
external/*/.next/

# Tool caches
.rechecker/
.tldr/
.claude/
.serena/
.expect/

