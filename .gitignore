# macOS
.DS_Store
._*

# Dev-only, never published (per ~/.claude/CLAUDE.md Rule 0.2)
docs_dev/
scripts_dev/
samples_dev/
examples_dev/
tests_dev/
downloads_dev/
libs_dev/
builds_dev/

# Agent reports — may contain absolute paths, stack traces, PII
# (per ~/.claude/rules/agent-reports-location.md)
/reports/
/reports_dev/

# Source material — read-only references, not shipped with the plugin
/SKILLS-TO-INTEGRATE/
/claude-design-principles/

# Local environments
.venv/
venv/
env/
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.codegraph/

# Node / Bun
node_modules/
.pnp.*
dist/
build/
.next/
.turbo/
.bun/
bun.lockb

# Plugin-specific build artifacts
bin/__pycache__/
bin/*.pyc

# External vendored repos — only their build artifacts, not the source
external/*/node_modules/
external/*/dist/
external/*/build/
external/*/.turbo/
external/*/.next/

# Tool caches
.rechecker/
.tldr/
# .claude/ holds tool-cache/state (settings, hooks) — ignore its contents,
# EXCEPT the git-tracked PROJECT-scope wiki-memory under .claude/project/memory/
# (ai-maestro memory 3-scope config; stood up by /janitor-memory-bootstrap).
.claude/**
!.claude/project/
!.claude/project/memory/
!.claude/project/memory/**
.serena/
.expect/

# Test / CI output
coverage/
*.lcov
.nyc_output/

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Hyperframes — EXTERNAL on-demand dependency, NOT vendored, NOT a submodule.
# `/amw-init` (or the amw-hyperframes-bridge skill on first render) clones
# https://github.com/heygen-com/hyperframes into this path at runtime; it is
# never committed and never part of the published plugin (the bridge shells out
# to `npx hyperframes`). Ignoring the whole tree keeps that runtime clone out of
# git AND out of CPV's scanners — its upstream code (Dockerfiles, TS sources) is
# heygen-com's, which this plugin neither owns nor may edit (RULE 0 + the
# cross-project rule). Removed as a git submodule on 2026-06-21: the committed
# gitlink made CPV scan the 244MB checkout and flag 20 CRITICAL / 20 MAJOR
# upstream findings; making hyperframes a pure runtime dependency clears the gate.
external/hyperframes/**

# NOTE: external/mermaid-render/ is now OWNED first-party code (MIT, wrapping
# the MIT beautiful-mermaid backend — see Acknowledgments in README.md). It is
# git-tracked and improvable; it is NOT skipped here. Its `node_modules/` /
# `dist/` / `build/` artifacts are still ignored by the `external/*/…` rules
# above. CPV scanners now lint it like any first-party code; the wrapper
# scripts' benign process.argv / process.env CLI reads are expected.

# NOTE: vendored shadcn-ui upstream docs (skills/amw-shadcn-ui/docs/, 201 MDX
# from ui.shadcn.com) are deliberately NOT gitignored. They are tracked + shipped
# (the skill references them) and CPV now treats a tracked+gitignored file as a
# blocking MAJOR (gitignore must imply not-shipped). Per the CPV maintainer
# (claude-plugins-validation#123): track-not-ignore + use `cpv.exclude_paths` in
# plugin.json to skip them from STYLE/STRUCTURE rules; they are security-scanned
# by design (vendored != trusted) — file any real MDX false-positive at CPV.

# Janitor heartbeat state (per-session, transient)
.janitor/

# Added by CPV standardize
llm_externalizer_output/
*_dev/
.coverage
